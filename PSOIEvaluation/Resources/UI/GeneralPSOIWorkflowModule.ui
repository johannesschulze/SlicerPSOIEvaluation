      </sizepolicy>
     </property>
     <property name="text">
      <string>&lt;h3&gt;Requirements&lt;/h3&gt;&lt;ol&gt;&lt;li&gt;Pre- and postop-CTs (DICOM) are loaded into the scene&lt;/li&gt;&lt;li&gt;Planning-STLs (skull and implant) are loaded into the scene&lt;/li&gt;&lt;/ol&gt;&lt;p style=&quot;font-weight: bold; text-align:center;&quot;&gt;Don't forget to cite this module when using it for published research. Thank You!&lt;/p&gt;</string>
     </property>
     <property name="wordWrap">
      <bool>true</bool>
     </property>
    </widget>
   </item>
   <item>
