     <widget class="QWidget" name="pageCalculateComparison">
      <property name="geometry">
       <rect>
        <x>0</x>
        <y>0</y>
        <width>684</width>
        <height>251</height>
       </rect>
      </property>
      <attribute name="label">
       <string>5. Calculate Comparison</string>
      </attribute>
      <layout class="QVBoxLayout" name="verticalLayout_6">
       <item>
        <widget class="QLabel" name="label_4">
         <property name="text">
          <string>&lt;p&gt;Performs the &lt;i&gt;model-to-model-comparison&lt;/i&gt; on a &lt;i&gt;Point-by-Point&lt;/i&gt; level, stores the information in a new model based on the planned model (vectors and distances are expressed as &lt;i&gt;from planned to postop&lt;/i&gt;) and displays the color-coded distance model&lt;/p&gt;</string>
