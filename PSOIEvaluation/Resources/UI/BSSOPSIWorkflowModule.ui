   <item>
    <widget class="QLabel" name="labelRamusDescription">
     <property name="sizePolicy">
      <sizepolicy hsizetype="Minimum" vsizetype="Preferred">
       <horstretch>0</horstretch>
       <verstretch>0</verstretch>
      </sizepolicy>
     </property>
     <property name="text">
      <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:700;&quot;&gt;Vorraussetzung:&lt;/span&gt;&lt;/p&gt;&lt;p&gt;1. Modelle für Unterkiefer geladen&lt;/p&gt;&lt;p&gt;2. Unterkiefer-Modelle korrekt benannt (mandible preop/planned/postop)&lt;/p&gt;&lt;p&gt;3. Ebenen eingezeichnet und korrekt benannt (&lt;span style=&quot; font-style:italic;&quot;&gt;parallel ramus plane&lt;/span&gt;, &lt;span style=&quot; font-style:italic;&quot;&gt;mandibular notch plane)&lt;/span&gt;. Wichtig Ebenen-Vektoren zeigen nach vorne bzw. unten&lt;/p&gt;&lt;p&gt;Zuerst mit &lt;span style=&quot; font-style:italic;&quot;&gt;Ramus-Aufteilung&lt;/span&gt; das Teilen und Croppen der Ramus-Modelle vornehmen.&lt;/p&gt;&lt;p&gt;Dann mit &lt;span style=&quot; font-style:italic;&quot;&gt;Wechsel zu Model To Model Distance &lt;/span&gt;in eben dieses Modul wechseln und dort entsprechend der Anleitung die M2M-Distanz für die Ramus-Modelle ermitteln&lt;/p&gt;&lt;p&gt;Zuletzt mit &lt;span style=&quot; font-style:italic;&quot;&gt;Ergebnisse ausgeben&lt;/span&gt; die CSV-Datei-Ausgabe für die Ergebnisse generieren&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
     </property>
