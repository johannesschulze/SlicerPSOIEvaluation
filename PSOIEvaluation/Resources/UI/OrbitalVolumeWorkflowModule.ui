   <item> <!-- Collapsible Volume Segmentation-->
     <widget class="ctkCollapsibleButton" name="pageVolumeSegmentation">
      <property name="geometry">
       <rect>
        <x>0</x>
        <y>-290</y>
        <width>668</width>
        <height>959</height>
       </rect>
      </property>
      <property name="text">
       <string>2. Segment Intraorbital Volume</string>
      </property>
      <property name="checked">
        <bool>false</bool>
      </property>
      <layout class="QVBoxLayout" name="verticalLayoutSegmentation">
       <item>
        <widget class="QLabel" name="labelSegmentationDescription">
         <property name="text">
          <string>&lt;p&gt;Segments the intraorbital soft tissue using &lt;b&gt;Fast Marching&lt;/b&gt;. The algorithm propagates from an automatically chosen seed point and is bounded by the orbital cylinder (depth + radius).&lt;/p&gt;</string>
         </property>
         <property name="wordWrap">
          <bool>true</bool>
         </property>
        </widget>
       </item>
       <item>
        <layout class="QFormLayout" name="formLayoutSegmentation">
         <item row="0" column="0">
          <widget class="QLabel" name="labelPlaneModel">
           <property name="text">
            <string>Orbital Plane (Mesh):</string>
           </property>
          </widget>
         </item>
         <item row="0" column="1">
          <widget class="qMRMLNodeComboBox" name="planeModelSelector" native="true">
           <property name="toolTip">
            <string>OrbitalPlane mesh from step 1</string>
           </property>
           <property name="nodeTypes" stdset="0">
            <stringlist notr="true">
             <string>vtkMRMLModelNode</string>
            </stringlist>
           </property>
           <property name="showChildNodeTypes" stdset="0">
            <bool>false</bool>
           </property>
           <property name="addEnabled" stdset="0">
            <bool>false</bool>
           </property>
           <property name="removeEnabled" stdset="0">
            <bool>false</bool>
           </property>
           <property name="noneEnabled" stdset="0">
            <bool>true</bool>
           </property>
          </widget>
         </item>
         <item row="1" column="0" colspan="2">
          <widget class="QLabel" name="labelHuHeader">
           <property name="text">
            <string>&lt;b&gt;HU Window for Seed Search:&lt;/b&gt;</string>
           </property>
          </widget>
         </item>
         <item row="2" column="0">
          <widget class="QLabel" name="labelHuMin">
           <property name="text">
            <string>HU Minimum:</string>
