        <string>Recalculate intraorbital volume</string>
       </property>
       <property name="text">
        <string>↺</string>
       </property>
       <property name="maximumWidth">
        <number>28</number>
       </property>
       <property name="maximumHeight">
        <number>28</number>
       </property>
       <property name="flat">
        <bool>true</bool>
       </property>
      </widget>
     </item>
    </layout>
   </item>

    <item> <!-- Export Button Label -->
    <widget class="QPushButton" name="exportResultsButton">
    <property name="toolTip">
    <string>Exports segmentation parameters and volumes for both sides to results_orbital_volume.xlsx in the CT volume's directory</string>
    </property>
    <property name="text">
    <string>Export Results (Excel)</string>
    </property>
    </widget>
   </item>

   <item> <!-- Vertical Spacer Bottom (expanding)-->
      <spacer name="verticalSpacerBottom">
        <property name="orientation">
           <enum>Qt::Vertical</enum>
        </property>
        <property name="sizeHint" stdset="0">
            <size>
                <width>40</width>
                <height>20</height>
            </size>
        </property>
        <property name="sizePolicy">
         <sizepolicy hsizetype="Fixed" vsizetype="Expanding">
          <horstretch>0</horstretch>
          <verstretch>0</verstretch>
         </sizepolicy>
        </property>
      </spacer>
    </item>
  </layout>
 </widget>
