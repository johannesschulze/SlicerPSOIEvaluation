          </widget>
         </item>
         <item row="16" column="1">
          <widget class="QCheckBox" name="useContralateralCheckBox">
           <property name="toolTip">
            <string>Uses the mirrored segmentation of the opposite orbit as the initial Fast Marching seed region (requires the contralateral side to be segmented first)</string>
           </property>
           <property name="enabled">
            <bool>false</bool>
           </property>
           <property name="checked">
            <bool>false</bool>
           </property>
          </widget>
         </item>

         <!-- Trennlinie: Nachbearbeitung -->
         <item row="17" column="0" colspan="2">
          <widget class="QLabel" name="labelPostprocessingHeader">
           <property name="text">
            <string>&lt;b&gt;Post-processing:&lt;/b&gt;</string>
           </property>
          </widget>
         </item>

         <item row="18" column="0">
          <widget class="QLabel" name="labelRemoveSatellites">
           <property name="text">
            <string>Remove Satellites:</string>
           </property>
          </widget>
         </item>
         <item row="18" column="1">
          <widget class="QCheckBox" name="removeSatellitesCheckBox">
           <property name="toolTip">
            <string>Remove small disconnected regions (satellites / trailing artefacts) after segmentation. Keeps only components whose effective diameter exceeds the threshold below.</string>
           </property>
           <property name="checked">
            <bool>true</bool>
           </property>
          </widget>
         </item>

         <item row="19" column="0">
          <widget class="QLabel" name="labelSatelliteDiam">
           <property name="text">
            <string>Min. Diameter (mm):</string>
           </property>
          </widget>
         </item>
         <item row="19" column="1">
          <widget class="QDoubleSpinBox" name="satelliteDiamSpinBox">
           <property name="toolTip">
            <string>Sphere-equivalent diameter threshold (mm). Connected components smaller than this are removed as satellite regions.</string>
           </property>
           <property name="minimum">
            <double>0.500000000000000</double>
           </property>
           <property name="maximum">
            <double>20.000000000000000</double>
           </property>
           <property name="singleStep">
            <double>0.500000000000000</double>
           </property>
           <property name="value">
            <double>3.000000000000000</double>
           </property>
          </widget>
         </item>

        </layout>
       </item>
       <item>
        <widget class="QPushButton" name="segmentVolumeButton">
         <property name="text">
          <string>Segment Volume</string>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QPushButton" name="openSegmentEditorButton">
         <property name="text">
          <string>Edit in Segment Editor (Scissors)</string>
         </property>
         <property name="toolTip">
          <string>Opens the Segment Editor with the Scissors tool active for manual corrections. The volume is automatically recalculated after editing.</string>
         </property>
         <property name="enabled">
          <bool>false</bool>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QLabel" name="segmentationResultLabel">
         <property name="text">
          <string/>
         </property>
         <property name="wordWrap">
          <bool>true</bool>
         </property>
        </widget>
       </item>
      </layout>
     </widget>

    </widget>
   </item>
  </layout>
 </widget>
