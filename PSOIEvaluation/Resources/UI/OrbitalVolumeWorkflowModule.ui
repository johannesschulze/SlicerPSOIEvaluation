     <widget class="QWidget" name="pageOrbitalSurface">
      <attribute name="label">
       <string>1. Create Orbital Entry Plane</string>
      </attribute>
      <layout class="QVBoxLayout" name="verticalLayoutSurface">
       <item>
        <widget class="QLabel" name="labelSurfaceDescription">
         <property name="text">
          <string>&lt;p&gt;Select a &lt;b&gt;Closed Curve&lt;/b&gt; along the orbital rim. The module triangulates the surface and creates a &lt;i&gt;ModelNode&lt;/i&gt; as the entry plane, which is automatically passed to step 2.&lt;/p&gt;</string>
         </property>
         <property name="wordWrap">
          <bool>true</bool>
         </property>
        </widget>
       </item>
