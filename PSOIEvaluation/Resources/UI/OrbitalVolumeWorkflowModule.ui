      <item>
       <widget class="QLabel" name="labelLandmarksDescription">
        <property name="text">
         <string>&lt;p&gt;Guided placement of &lt;b&gt;10 standardized anatomical landmarks&lt;/b&gt; (L1–L10) along the orbital rim for SSM / SlicerSALT. After all 10 are placed, generate a closed curve for Step 1.&lt;/p&gt;</string>
        </property>
        <property name="wordWrap">
         <bool>true</bool>
        </property>
       </widget>
      </item>
